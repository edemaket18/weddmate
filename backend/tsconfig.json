{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",

    "outDir": "./dist",
    "rootDir": "./src",

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,
    "resolveJsonModule": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "types": [
      "node",
      "express",
      "cors",
      "morgan",
      "jsonwebtoken",
      "qrcode"
    ]
  },

  "include": [
    "src/**/*",
    "src/**/*.d.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}